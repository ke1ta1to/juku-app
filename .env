# ── コピーして .env にリネームし、本番値に書き換えること ────────────────────

# アプリURL（QRコードに埋め込む。本番では実際のURLに変更）
BASE_URL=http://localhost:8000

# DB
DATABASE_URL=sqlite:///./juku.db
# DATABASE_URL=postgresql://user:password@localhost:5432/juku_db

# JWT（openssl rand -hex 32 で生成）
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=480

# QR（openssl rand -hex 32 で別途生成。JWTと同じ値にしないこと）
QR_SECRET_KEY=CHANGE_ME_QR_SECRET_IN_PRODUCTION
QR_TOKEN_EXPIRE_SECONDS=60
ACADEMY_ID=juku01
QR_GRACE_WINDOWS=1
QR_DISPLAY_KEY=changeme-display-key

# デバッグ（本番は False）
DEBUG=True

# ── 初期管理者シード ─────────────────────────────────────────────────────────
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=changeme1234!
INITIAL_ADMIN_NAME=管理者

# ── 不正検知 ─────────────────────────────────────────────────────────────────
# 1トークンで許容するスキャン数（塾の生徒数を目安に）
QR_ABUSE_SCAN_LIMIT=50

# 同一IPから N秒以内に M回スキャンでアラート
IP_BURST_LIMIT=10
IP_BURST_WINDOW_SECS=60

# 同一ユーザーが別端末から N分以内にスキャンでアラート（代理スキャン検知）
DEVICE_MISMATCH_WINDOW_MINS=5
